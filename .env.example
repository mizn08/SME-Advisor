# Copy to .env in the project root:  cp .env.example .env

# PostgreSQL (db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bnpl_db
POSTGRES_PORT=5432

# FastAPI
API_PORT=8000
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bnpl_db

# ML artefacts path inside the backend container
ML_MODELS_DIR=/app/backend/app/ml_models

# Optional pgAdmin (docker compose --profile tools up)
PGADMIN_DEFAULT_EMAIL=admin@bnpl.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# DB wait tuning (entrypoint scripts)
DB_WAIT_ATTEMPTS=60
DB_WAIT_INTERVAL=2

# v2 — RAG + LangChain (optional; works offline without OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
APP_ENV=development
AWS_REGION=ap-southeast-1

# v3 — vector RAG, bandit, RL
USE_VECTOR_RAG=true
CHROMA_PERSIST_DIR=data/chroma
RL_Q_TABLE_PATH=data/rl_q_table.json
FINETUNE_ADAPTER_DIR=data/finetune_adapter
FINETUNE_BASE_MODEL=microsoft/Phi-3-mini-4k-instruct

# v4 APC+ (auth off for local demo)
AUTH_REQUIRED=false
API_KEY=
JWT_SECRET=change-me-in-production
RATE_LIMIT=120/minute
