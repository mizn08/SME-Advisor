# Copy to .env in the project root:  cp .env.example .env

# PostgreSQL (db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bnpl_db
POSTGRES_PORT=5432

# FastAPI
API_PORT=8000
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/bnpl_db

# ML artefacts path inside the backend container
ML_MODELS_DIR=/app/backend/app/ml_models

# Optional pgAdmin (docker compose --profile tools up)
PGADMIN_DEFAULT_EMAIL=admin@bnpl.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# DB wait tuning (entrypoint scripts)
DB_WAIT_ATTEMPTS=60
DB_WAIT_INTERVAL=2
